# Database - Supabase PostgreSQL connection string
# For Vercel/serverless: use the Connection Pooling URL (port 6543)
DATABASE_URL="postgresql://user:password@host:6543/dbname"
# For migrations/introspection: use the direct connection (port 5432)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth - Generate a strong secret: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_STRING"

# Admin credentials
ADMIN_USERNAME="anfitrion"
# Generate with: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('YOUR_PASSWORD', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
